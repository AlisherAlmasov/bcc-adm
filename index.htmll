const TX = [
  {id:'#TX-9841',from:'Ерлан Омаров',to:'Гүлнар Сейтова',type:'Перевод',tc:'bg-b',amount:'+₸ 150 000',pos:true,fee:'₸ 150',date:'29.06.2026 14:32',status:'Успешно',sc:'bg-g'},
  {id:'#TX-9840',from:'Гүлнар Сейтова',to:'KazMunaiGaz',type:'Оплата',tc:'bg-gray',amount:'-₸ 45 000',pos:false,fee:'₸ 0',date:'29.06.2026 13:15',status:'Успешно',sc:'bg-g'},
  {id:'#TX-9839',from:'Асхат Джаксыбеков',to:'Нал (ATM)',type:'Снятие',tc:'bg-gray',amount:'-₸ 200 000',pos:false,fee:'₸ 0',date:'29.06.2026 12:40',status:'В обработке',sc:'bg-y'},
  {id:'#TX-9838',from:'Каспийбанк',to:'Дина Нурланова',type:'Пополнение',tc:'bg-g',amount:'+₸ 500 000',pos:true,fee:'₸ 0',date:'29.06.2026 11:05',status:'Успешно',sc:'bg-g'},
  {id:'#TX-9837',from:'Марат Тасов',to:'Unknown',type:'Перевод',tc:'bg-b',amount:'-₸ 4 500 000',pos:false,fee:'₸ 500',date:'29.06.2026 03:47',status:'Отклонено',sc:'bg-r'},
  {id:'#TX-9836',from:'Айгерим Байжанова',to:'Kaspi Pay',type:'Оплата',tc:'bg-gray',amount:'-₸ 12 500',pos:false,fee:'₸ 0',date:'28.06.2026 22:30',status:'Успешно',sc:'bg-g'},
  {id:'#TX-9835',from:'Бекжан Уразов',to:'BI Group LLC',type:'Перевод',tc:'bg-b',amount:'-₸ 8 000 000',pos:false,fee:'₸ 800',date:'28.06.2026 18:10',status:'Успешно',sc:'bg-g'},
  {id:'#TX-9834',from:'Зарина Мусина',to:'Персонал (зарплата)',type:'Зарплата',tc:'bg-p',amount:'-₸ 15 200 000',pos:false,fee:'₸ 0',date:'28.06.2026 12:00',status:'Успешно',sc:'bg-g'},
];

// ── RENDER CLIENTS ──
function renderClients(list){
  const sb = {Активен:'bg-g', Заблокирован:'bg-r', Ожидание:'bg-y'};
  document.getElementById('clBody').innerHTML = list.map(c=>`
    <tr>
      <td><strong>${c.name}</strong></td>
      <td style="font-family:monospace;font-size:12px;color:var(--gray-light)">${c.iin}</td>
      <td style="color:var(--gray)">${c.phone}</td>
      <td><span class="badge bg-gray">${c.type}</span></td>
      <td style="font-weight:600">${c.balance}</td>
      <td style="text-align:center"><span class="badge bg-b">${c.cards}</span></td>
      <td style="color:var(--gray-light);font-size:12px">${c.reg}</td>
      <td><span class="badge ${sb[c.status]}">${c.status}</span></td>
      <td><button class="card-link" style="font-size:12px">Открыть →</button></td>
    </tr>`).join('');
}

function filterClients(){
  const q = document.getElementById('clSearch').value.toLowerCase();
  const s = document.getElementById('clStatus').value;
  renderClients(CLIENTS.filter(c=>{
    const m = !q || c.name.toLowerCase().includes(q) || c.iin.includes(q) || c.phone.includes(q);
    const ms = !s || c.status === s;
    return m && ms;
  }));
}

// ── RENDER TX ──
function renderTx(){
  document.getElementById('txBody').innerHTML = TX.map(t=>`
    <tr>
      <td style="font-family:monospace;font-size:12px;color:var(--gray-light)">${t.id}</td>
      <td><strong>${t.from}</strong></td>
      <td style="color:var(--gray)">${t.to}</td>
      <td><span class="badge ${t.tc}">${t.type}</span></td>
      <td style="font-weight:700;color:${t.pos?'var(--green)':'#ef4444'}">${t.amount}</td>
      <td style="color:var(--gray-light)">${t.fee}</td>
      <td style="color:var(--gray-light);font-size:12px">${t.date}</td>
      <td><span class="badge ${t.sc}">${t.status}</span></td>
    </tr>`).join('');
}

renderClients(CLIENTS);
renderTx();

// ── NAVIGATION ──
const PAGE_TITLES = {dashboard:'Дашборд',clients:'Клиенты',transactions:'Транзакции',cards:'Карты',analytics:'Аналитика',security:'Безопасность',settings:'Настройки'};

function nav(el){
  const pid = el.dataset.page;
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('pg-'+pid).classList.add('active');
  document.getElementById('hTitle').textContent = PAGE_TITLES[pid]||pid;
  if(pid==='analytics') setTimeout(initAnalyticsCharts, 60);
  // close mobile sidebar
  document.getElementById('sidebar').classList.remove('open');
}

// ── THEME ──
let dark = false;
const charts = {};

function toggleTheme(){
  dark = !dark;
  document.body.classList.toggle('dark', dark);
  document.getElementById('themeBtn').textContent = dark ? '☀️ Светлая' : '🌙 Тёмная';
  setTimeout(reinitAllCharts, 80);
}

function toggleFull(){
  if(!document.fullscreenElement) document.documentElement.requestFullscreen().catch(()=>{});
  else document.exitFullscreen();
}

// ── CHARTS HELPERS ──
function gc(){ // get chart colors
  return {
    grid: dark ? 'rgba(255,255,255,.06)' : 'rgba(0,0,0,.05)',
    tick: dark ? '#475569' : '#9ca3af',
    tooltip: {
      bg: dark?'#1e293b':'#ffffff',
      title: dark?'#f1f5f9':'#111827',
      body: dark?'#94a3b8':'#6b7280',
      border: dark?'#334155':'#e5e7eb',
    }
  };
}

function tooltipOpts(C){
  return {
    backgroundColor:C.tooltip.bg,
    titleColor:C.tooltip.title,
    bodyColor:C.tooltip.body,
    borderColor:C.tooltip.border,
    borderWidth:1,
    padding:10,
    cornerRadius:8,
  };
}

function destroyChart(key){
  if(charts[key]){ try{charts[key].destroy()}catch(e){} delete charts[key]; }
}

function initDashCharts(){
  const C = gc();
  const months = ['Июл','Авг','Сен','Окт','Ноя','Дек','Янв','Фев','Мар','Апр','Май','Июн'];
  const revenue = [8.2,9.1,8.8,10.4,11.2,10.9,12.3,13.1,12.8,13.9,14.1,14.7];

  destroyChart('revenue');
  const rc = document.getElementById('c-revenue');
  if(rc) charts['revenue'] = new Chart(rc,{
    type:'line',
    data:{
      labels:months,
      datasets:[{
        label:'Доход (млрд ₸)',data:revenue,
        borderColor:'#22c55e',borderWidth:2.5,
        pointBackgroundColor:'#22c55e',pointRadius:4,pointHoverRadius:7,
        fill:true,
        backgroundColor: dark ? 'rgba(34,197,94,.12)' : 'rgba(34,197,94,.08)',
        tension:0.4,
      }]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{...tooltipOpts(C),callbacks:{label:ctx=>`₸ ${ctx.parsed.y.toFixed(1)} млрд`}}
      },
      scales:{
        x:{grid:{color:C.grid},ticks:{color:C.tick,font:{size:11}}},
        y:{grid:{color:C.grid},ticks:{color:C.tick,font:{size:11},callback:v=>`${v}млрд`}}
      }
    }
  });

  destroyChart('doughnut');
  const dc = document.getElementById('c-doughnut');
  if(dc) charts['doughnut'] = new Chart(dc,{
    type:'doughnut',
    data:{
      labels:['Переводы','Оплата','Снятие'],
      datasets:[{data:[48,31,21],backgroundColor:['#22c55e','#2a78d6','#7c3aed'],borderWidth:0,hoverOffset:8}]
    },
    options:{
      responsive:true,maintainAspectRatio:false,cutout:'72%',
      plugins:{legend:{display:false},tooltip:{...tooltipOpts(C),callbacks:{label:ctx=>`${ctx.label}: ${ctx.parsed}%`}}}
    }
  });
}

function initAnalyticsCharts(){
  const C = gc();
  const hours = Array.from({length:24},(_,i)=>i+':00');
  const hdata = [120,80,45,30,20,25,180,420,850,1200,1400,1550,1480,1600,1420,1380,1290,1100,980,870,720,580,380,210];

  destroyChart('hourly');
  const hc = document.getElementById('c-hourly');
  if(hc) charts['hourly'] = new Chart(hc,{
    type:'bar',
    data:{labels:hours,datasets:[{label:'Транзакции',data:hdata,backgroundColor:dark?'rgba(34,197,94,.2)':'rgba(34,197,94,.15)',borderColor:'#22c55e',borderWidth:1.5,borderRadius:3,borderSkipped:false}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:tooltipOpts(C)},scales:{x:{grid:{color:C.grid},ticks:{color:C.tick,font:{size:10},maxTicksLimit:8,autoSkip:true}},y:{grid:{color:C.grid},ticks:{color:C.tick,font:{size:10}}}}}
  });

  destroyChart('weekly');
  const wc = document.getElementById('c-weekly');
  if(wc) charts['weekly'] = new Chart(wc,{
    type:'bar',
    data:{
      labels:['Пн','Вт','Ср','Чт','Пт','Сб','Вс'],
      datasets:[
        {label:'Активные',data:[142000,138000,151000,160000,155000,98000,72000],backgroundColor:'#22c55e',borderRadius:4,borderSkipped:false},
        {label:'Новые',data:[8200,7100,9400,10100,8800,5200,3100],backgroundColor:'#2a78d6',borderRadius:4,borderSkipped:false},
      ]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:tooltipOpts(C)},scales:{x:{grid:{color:C.grid},ticks:{color:C.tick}},y:{grid:{color:C.grid},ticks:{color:C.tick}}}}
  });
}

function reinitAllCharts(){
  initDashCharts();
  if(document.getElementById('pg-analytics').classList.contains('active')) initAnalyticsCharts();
}

// ── ADMIN PROFILE ──
const admin = {
  name: 'Алия Каримова',
  role: 'Главный администратор',
  email: 'admin@bcc.kz',
};

function initials(name){
  return name.trim().split(/\s+/).map(w=>w[0]||'').join('').slice(0,2).toUpperCase() || '??';
}

function applyAdmin(){
  const av = initials(admin.name);
  const firstName = admin.name.split(' ')[0] || admin.name;

  // Sidebar
  document.getElementById('sidebarAv').textContent = av;
  document.getElementById('sidebarName').textContent = admin.name;
  document.getElementById('sidebarRole').textContent = admin.role;

  // Header
  document.getElementById('headerAv').textContent = av;
  document.getElementById('headerAv').title = admin.name;

  // Dashboard greeting
  const today = new Date().toLocaleDateString('ru-RU',{day:'numeric',month:'long',year:'numeric'});
  document.getElementById('dashGreeting').textContent = `Добро пожаловать, ${firstName} — сегодня ${today}`;
}

function openModal(){
  document.getElementById('inputName').value = admin.name;
  document.getElementById('inputRole').value = admin.role;
  document.getElementById('inputEmail').value = admin.email;
  document.getElementById('modalAvText').textContent = initials(admin.name);
  document.getElementById('profileModal').classList.add('open');
  setTimeout(()=>document.getElementById('inputName').focus(), 220);

  // live preview of initials while typing
  document.getElementById('inputName').oninput = function(){
    document.getElementById('modalAvText').textContent = initials(this.value) || '??';
  };
}

function closeModal(){
  document.getElementById('profileModal').classList.remove('open');
}

function saveProfile(){
  const name = document.getElementById('inputName').value.trim();
  const role = document.getElementById('inputRole').value.trim();
  const email = document.getElementById('inputEmail').value.trim();

  if(!name){ document.getElementById('inputName').focus(); return; }

  admin.name = name;
  admin.role = role || admin.role;
  admin.email = email || admin.email;

  applyAdmin();
  closeModal();
  showToast(`✅ Профиль обновлён — ${name}`);
}

function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 3000);
}

// Close modal on Escape
document.addEventListener('keydown', e => { if(e.key==='Escape') closeModal(); });

// Apply initial admin data on load
window.addEventListener('DOMContentLoaded', ()=>{
  applyAdmin();
  setTimeout(initDashCharts, 100);
  if(window.innerWidth < 768) document.getElementById('menuBtn').style.display = 'flex';
});

window.addEventListener('resize',()=>{
  const mb = document.getElementById('menuBtn');
  if(window.innerWidth < 768){ mb.style.display='flex'; }
  else { mb.style.display='none'; document.getElementById('sidebar').classList.remove('open'); }
});
</script>
</body>
</html>
