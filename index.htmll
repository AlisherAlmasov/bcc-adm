<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bank CenterCredit — Панель управления</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --green:#16a34a;--green-light:#22c55e;--green-dark:#15803d;
  --green-bg:#f0fdf4;--green-bg2:#dcfce7;
  --dark:#111827;--dark2:#1f2937;--dark3:#374151;
  --gray:#6b7280;--gray-light:#9ca3af;
  --bg:#f1f5f9;--card-bg:#ffffff;--border:#e5e7eb;
  --sidebar-bg:#111827;--sidebar-text:rgba(255,255,255,.65);
  --sidebar-w:240px;--header-h:64px;
  --radius:12px;--radius-sm:8px;
  --shadow:0 1px 3px rgba(0,0,0,.1),0 1px 2px rgba(0,0,0,.06);
  --shadow-md:0 4px 20px rgba(0,0,0,.08);
  --tr:.2s ease;
}
body.dark{
  --dark:#f1f5f9;--dark2:#e2e8f0;--dark3:#cbd5e1;
  --gray:#94a3b8;--gray-light:#64748b;
  --bg:#0f172a;--card-bg:#1e293b;--border:#334155;
  --sidebar-bg:#020617;--sidebar-text:rgba(255,255,255,.55);
  --green-bg:#052e16;--green-bg2:#14532d;
}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--dark);overflow:hidden;height:100vh;transition:background var(--tr),color var(--tr)}

/* ── LAYOUT ── */
.app{display:flex;height:100vh;overflow:hidden}

/* ── SIDEBAR ── */
.sidebar{
  width:var(--sidebar-w);min-width:var(--sidebar-w);height:100vh;
  background:var(--sidebar-bg);display:flex;flex-direction:column;
  transition:var(--tr);z-index:200;flex-shrink:0;
}
.sidebar-logo{
  padding:18px 16px 14px;border-bottom:1px solid rgba(255,255,255,.07);
  display:flex;align-items:center;gap:10px;
}
.logo-mark{
  width:38px;height:38px;border-radius:10px;
  background:linear-gradient(135deg,#22c55e,#15803d);
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:13px;color:white;flex-shrink:0;letter-spacing:-.5px;
}
.logo-name{font-size:13px;font-weight:700;color:white;line-height:1.2}
.logo-sub{font-size:10px;color:rgba(255,255,255,.35);font-weight:400;margin-top:1px}
.sidebar-scroll{flex:1;overflow-y:auto;padding:8px 10px 0}
.sidebar-scroll::-webkit-scrollbar{width:0}
.nav-label{font-size:10px;font-weight:600;color:rgba(255,255,255,.28);padding:14px 8px 5px;letter-spacing:.1em;text-transform:uppercase}
.nav-item{
  display:flex;align-items:center;gap:10px;padding:8px 10px;
  border-radius:8px;cursor:pointer;margin-bottom:1px;
  font-size:13px;font-weight:500;color:var(--sidebar-text);
  transition:var(--tr);user-select:none;position:relative;
}
.nav-item:hover{background:rgba(255,255,255,.07);color:rgba(255,255,255,.9)}
.nav-item.active{background:var(--green);color:white}
.nav-item svg{width:16px;height:16px;flex-shrink:0;opacity:.8}
.nav-item.active svg{opacity:1}
.nav-badge{
  margin-left:auto;background:rgba(239,68,68,.85);color:white;
  font-size:10px;font-weight:700;padding:2px 6px;border-radius:99px;
}
.sidebar-foot{padding:10px;border-top:1px solid rgba(255,255,255,.07)}
.usr{display:flex;align-items:center;gap:10px;padding:8px;border-radius:8px;cursor:pointer}
.usr:hover{background:rgba(255,255,255,.06)}
.usr-av{
  width:32px;height:32px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,#22c55e,#059669);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;color:white;
}
.usr-name{font-size:12px;font-weight:600;color:rgba(255,255,255,.9)}
.usr-role{font-size:10px;color:rgba(255,255,255,.35)}

/* ── MAIN ── */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}

/* ── HEADER ── */
.header{
  height:var(--header-h);background:var(--card-bg);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 24px;gap:14px;flex-shrink:0;
  transition:background var(--tr),border-color var(--tr);
}
.h-title{font-size:15px;font-weight:700;color:var(--dark);flex:1}
.search{
  display:flex;align-items:center;gap:8px;
  background:var(--bg);border:1px solid var(--border);
  border-radius:8px;padding:7px 12px;width:210px;transition:var(--tr);
}
.search:focus-within{border-color:var(--green);box-shadow:0 0 0 3px rgba(22,163,74,.12)}
.search input{border:none;background:none;font-size:13px;color:var(--dark);outline:none;width:100%;font-family:inherit}
.search input::placeholder{color:var(--gray-light)}
.h-actions{display:flex;align-items:center;gap:8px}
.icon-btn{
  width:36px;height:36px;border-radius:8px;border:1px solid var(--border);
  background:none;display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--gray);transition:var(--tr);position:relative;
}
.icon-btn:hover{background:var(--bg);color:var(--dark)}
.notif-dot{position:absolute;top:7px;right:7px;width:7px;height:7px;border-radius:50%;background:#ef4444;border:2px solid var(--card-bg)}
.h-avatar{
  width:36px;height:36px;border-radius:50%;cursor:pointer;
  background:linear-gradient(135deg,#22c55e,#059669);
  display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:white;
}
.theme-btn{
  border:1px solid var(--border);border-radius:8px;padding:5px 10px;
  font-size:12px;font-weight:500;cursor:pointer;color:var(--gray);
  background:none;font-family:inherit;transition:var(--tr);white-space:nowrap;
}
.theme-btn:hover{color:var(--dark);background:var(--bg)}

/* ── CONTENT ── */
.content{flex:1;overflow-y:auto;padding:24px;background:var(--bg);transition:background var(--tr)}
.content::-webkit-scrollbar{width:5px}
.content::-webkit-scrollbar-track{background:transparent}
.content::-webkit-scrollbar-thumb{background:rgba(0,0,0,.12);border-radius:3px}
body.dark .content::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08)}

/* ── PAGES ── */
.page{display:none;animation:fadeUp .22s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

.page-head{margin-bottom:22px}
.page-title{font-size:20px;font-weight:700;color:var(--dark)}
.page-sub{font-size:13px;color:var(--gray);margin-top:3px}

/* ── CARDS ── */
.card{
  background:var(--card-bg);border-radius:var(--radius);
  border:1px solid var(--border);padding:20px;
  transition:background var(--tr),border-color var(--tr);
}
.card-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px}
.card-title{font-size:14px;font-weight:600;color:var(--dark)}
.card-link{font-size:12px;color:var(--green);background:none;border:none;cursor:pointer;font-family:inherit;font-weight:500}
.card-link:hover{text-decoration:underline}

/* ── STAT CARDS ── */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:22px}
.stat{
  background:var(--card-bg);border-radius:var(--radius);border:1px solid var(--border);
  padding:18px 20px;cursor:default;transition:var(--tr),box-shadow var(--tr);
  border-top:3px solid transparent;
}
.stat:hover{box-shadow:var(--shadow-md);transform:translateY(-2px)}
.stat.g{border-top-color:var(--green)}
.stat.b{border-top-color:#2563eb}
.stat.p{border-top-color:#7c3aed}
.stat.o{border-top-color:#ea580c}
.stat-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
.stat-lbl{font-size:11px;font-weight:600;color:var(--gray);text-transform:uppercase;letter-spacing:.05em}
.stat-ico{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center}
.ico-g{background:var(--green-bg2);color:var(--green)}
.ico-b{background:#dbeafe;color:#2563eb}
.ico-p{background:#ede9fe;color:#7c3aed}
.ico-o{background:#ffedd5;color:#ea580c}
body.dark .ico-g{background:#052e16;color:#4ade80}
body.dark .ico-b{background:#1e3a5f;color:#60a5fa}
body.dark .ico-p{background:#3b0764;color:#c084fc}
body.dark .ico-o{background:#431407;color:#fb923c}
.stat-val{font-size:22px;font-weight:700;color:var(--dark);margin-bottom:5px}
.stat-chg{font-size:12px;font-weight:500;color:var(--green)}
.stat-chg.neg{color:#ef4444}

/* ── GRIDS ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.g-rev{display:grid;grid-template-columns:2fr 1fr;gap:16px}
.mb16{margin-bottom:16px}
.mb22{margin-bottom:22px}

/* ── TABLES ── */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px}
thead th{
  padding:9px 12px;text-align:left;font-size:11px;font-weight:600;
  color:var(--gray-light);text-transform:uppercase;letter-spacing:.05em;
  border-bottom:1px solid var(--border);white-space:nowrap;
}
tbody td{
  padding:11px 12px;border-bottom:1px solid var(--border);
  color:var(--dark2);vertical-align:middle;
}
tbody tr:last-child td{border:none}
tbody tr:hover td{background:rgba(0,0,0,.02)}
body.dark tbody tr:hover td{background:rgba(255,255,255,.02)}

/* ── TABLE CONTROLS ── */
.tbl-ctrl{display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.t-search{
  flex:1;min-width:180px;display:flex;align-items:center;gap:8px;
  background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:7px 12px;
}
.t-search:focus-within{border-color:var(--green)}
.t-search input{border:none;background:none;font-size:13px;color:var(--dark);outline:none;width:100%;font-family:inherit}
.t-search input::placeholder{color:var(--gray-light)}
.fsel{
  border:1px solid var(--border);border-radius:8px;padding:7px 10px;
  font-size:13px;color:var(--dark);background:var(--card-bg);font-family:inherit;
  cursor:pointer;outline:none;transition:var(--tr);
}
.fsel:focus{border-color:var(--green)}
body.dark .fsel{background:var(--card-bg);color:var(--dark)}

/* ── BADGES ── */
.badge{display:inline-flex;align-items:center;padding:3px 8px;border-radius:99px;font-size:11px;font-weight:600;white-space:nowrap}
.bg-g{background:#dcfce7;color:#15803d}
.bg-r{background:#fee2e2;color:#dc2626}
.bg-y{background:#fef9c3;color:#a16207}
.bg-b{background:#dbeafe;color:#1d4ed8}
.bg-gray{background:#f3f4f6;color:#4b5563}
.bg-p{background:#ede9fe;color:#6d28d9}
body.dark .bg-g{background:#052e16;color:#4ade80}
body.dark .bg-r{background:#450a0a;color:#f87171}
body.dark .bg-y{background:#422006;color:#fbbf24}
body.dark .bg-b{background:#1e3a5f;color:#60a5fa}
body.dark .bg-gray{background:#1e293b;color:#94a3b8}
body.dark .bg-p{background:#3b0764;color:#c084fc}

/* ── MINI LIST ── */
.mini-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)}
.mini-row:last-child{border:none;padding-bottom:0}
.mini-lbl{font-size:12px;color:var(--gray);font-weight:500}
.mini-val{font-size:14px;font-weight:600;color:var(--dark)}

/* ── PROGRESS ── */
.prog-wrap{margin-bottom:10px}
.prog-top{display:flex;justify-content:space-between;font-size:12px;margin-bottom:5px}
.prog-name{font-weight:500;color:var(--dark)}
.prog-pct{font-weight:600}
.prog{height:5px;background:var(--border);border-radius:99px;overflow:hidden}
.prog-fill{height:100%;border-radius:99px;transition:width .8s ease}

/* ── ACTIVITY ── */
.act-item{display:flex;gap:12px;align-items:flex-start;padding:11px 0;border-bottom:1px solid var(--border)}
.act-item:last-child{border:none}
.act-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px}
.act-text{font-size:13px;color:var(--dark2);line-height:1.4}
.act-time{font-size:11px;color:var(--gray-light);margin-top:2px}
.act-sub{font-size:11px;color:var(--gray-light)}

/* ── ALERT ITEMS ── */
.alert-item{
  display:flex;gap:12px;align-items:flex-start;padding:14px;
  background:var(--bg);border-radius:8px;margin-bottom:8px;
  border:1px solid var(--border);transition:var(--tr);
}
.alert-item:last-child{margin-bottom:0}
.alert-item:hover{border-color:var(--green)}
.alert-ico{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:16px}
.ai-warn{background:#fff7ed;color:#c2410c}
.ai-danger{background:#fef2f2;color:#dc2626}
.ai-info{background:#eff6ff;color:#2563eb}
body.dark .ai-warn{background:#431407;color:#fb923c}
body.dark .ai-danger{background:#450a0a;color:#f87171}
body.dark .ai-info{background:#1e3a5f;color:#60a5fa}
.alert-title{font-size:13px;font-weight:600;color:var(--dark);margin-bottom:3px}
.alert-desc{font-size:12px;color:var(--gray)}
.alert-ts{font-size:11px;color:var(--gray-light);margin-top:4px}

/* ── BANK CARD ── */
.bank-card{
  border-radius:16px;padding:22px;color:white;position:relative;
  overflow:hidden;margin-bottom:12px;cursor:default;
  transition:transform var(--tr),box-shadow var(--tr);
}
.bank-card:hover{transform:translateY(-3px);box-shadow:0 12px 32px rgba(0,0,0,.2)}
.bc-green{background:linear-gradient(135deg,#15803d 0%,#166534 55%,#14532d 100%)}
.bc-blue{background:linear-gradient(135deg,#1d4ed8 0%,#1e40af 55%,#1e3a8a 100%)}
.bc-dark{background:linear-gradient(135deg,#1f2937 0%,#111827 55%,#030712 100%)}
.bc-glow::before{content:'';position:absolute;top:-50px;right:-50px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,.07)}
.bc-glow::after{content:'';position:absolute;bottom:-70px;right:20px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.04)}
.bc-chip{width:32px;height:24px;background:rgba(255,255,255,.28);border-radius:4px;margin-bottom:20px;position:relative;z-index:1}
.bc-num{font-size:15px;font-weight:400;letter-spacing:.16em;margin-bottom:18px;opacity:.9;position:relative;z-index:1}
.bc-foot{display:flex;justify-content:space-between;align-items:flex-end;position:relative;z-index:1}
.bc-holder-lbl{font-size:10px;opacity:.5;margin-bottom:3px;text-transform:uppercase;letter-spacing:.06em}
.bc-holder-name{font-size:13px;font-weight:600}
.bc-exp-lbl{font-size:10px;opacity:.5;text-align:right;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.bc-exp-val{font-size:13px;font-weight:600;text-align:right}
.bc-type{font-size:17px;font-weight:800;text-align:right;margin-top:2px;opacity:.85}

/* ── SETTINGS ── */
.set-section{margin-bottom:20px}
.set-title{font-size:13px;font-weight:700;color:var(--dark);margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:.05em}
.set-row{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--border)}
.set-row:last-child{border:none}
.set-lbl{font-size:13px;font-weight:500;color:var(--dark)}
.set-desc{font-size:11px;color:var(--gray);margin-top:2px}
.set-val{font-size:12px;color:var(--gray-light);text-align:right}
.toggle{width:40px;height:22px;border-radius:99px;background:var(--border);position:relative;cursor:pointer;transition:var(--tr);border:none;flex-shrink:0}
.toggle.on{background:var(--green)}
.toggle::after{content:'';position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:white;transition:var(--tr)}
.toggle.on::after{left:21px}

/* ── CHART CANVAS ── */
.chart-box{position:relative}

/* ── KPI ROW ── */
.kpi-row{display:flex;gap:10px;margin-bottom:8px;flex-wrap:wrap}
.kpi{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 14px;flex:1;min-width:100px}
.kpi-lbl{font-size:10px;color:var(--gray);text-transform:uppercase;letter-spacing:.05em;font-weight:600;margin-bottom:4px}
.kpi-val{font-size:16px;font-weight:700;color:var(--dark)}
.kpi-chg{font-size:11px;color:var(--green);font-weight:500}

/* ── RESPONSIVE ── */
@media(max-width:1024px){.stats-grid{grid-template-columns:repeat(2,1fr)}.g-rev{grid-template-columns:1fr}}
@media(max-width:768px){
  .sidebar{position:fixed;left:-250px;top:0;bottom:0}
  .sidebar.open{left:0;box-shadow:4px 0 20px rgba(0,0,0,.25)}
  .mb-menu-btn{display:flex!important}
  .search{width:160px}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .g2,.g3{grid-template-columns:1fr}
  .content{padding:16px}
}
@media(max-width:480px){.stats-grid{grid-template-columns:1fr}}
.mb-menu-btn{display:none;background:none;border:none;cursor:pointer;color:var(--gray);padding:4px 6px;margin-right:4px}

/* ── MODAL ── */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;transition:opacity .2s ease;
}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{
  background:var(--card-bg);border-radius:16px;border:1px solid var(--border);
  padding:28px;width:100%;max-width:380px;
  transform:translateY(12px) scale(.97);transition:transform .22s ease;
  box-shadow:0 20px 60px rgba(0,0,0,.2);
}
.modal-overlay.open .modal{transform:none}
.modal-title{font-size:16px;font-weight:700;color:var(--dark);margin-bottom:4px}
.modal-sub{font-size:12px;color:var(--gray);margin-bottom:22px}
.modal-av{
  width:64px;height:64px;border-radius:50%;
  background:linear-gradient(135deg,#22c55e,#059669);
  display:flex;align-items:center;justify-content:center;
  font-size:22px;font-weight:700;color:white;
  margin:0 auto 20px;cursor:pointer;position:relative;
  transition:filter .2s;
}
.modal-av:hover{filter:brightness(1.1)}
.modal-av-badge{
  position:absolute;bottom:0;right:0;width:22px;height:22px;
  border-radius:50%;background:var(--green);border:2px solid var(--card-bg);
  display:flex;align-items:center;justify-content:center;font-size:11px;
}
.field-group{margin-bottom:16px}
.field-label{font-size:12px;font-weight:600;color:var(--gray);margin-bottom:6px;display:block;text-transform:uppercase;letter-spacing:.05em}
.field-input{
  width:100%;border:1px solid var(--border);border-radius:8px;
  padding:9px 12px;font-size:14px;color:var(--dark);
  background:var(--bg);font-family:inherit;outline:none;
  transition:border-color .15s,box-shadow .15s;
}
.field-input:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(22,163,74,.12)}
body.dark .field-input{background:#0f172a;color:var(--dark)}
.modal-actions{display:flex;gap:10px;margin-top:22px}
.btn-primary{
  flex:1;background:var(--green);color:white;border:none;
  border-radius:8px;padding:10px;font-size:14px;font-weight:600;
  cursor:pointer;font-family:inherit;transition:.15s;
}
.btn-primary:hover{background:var(--green-dark)}
.btn-secondary{
  background:none;border:1px solid var(--border);border-radius:8px;
  padding:10px 16px;font-size:14px;font-weight:500;color:var(--gray);
  cursor:pointer;font-family:inherit;transition:.15s;
}
.btn-secondary:hover{background:var(--bg);color:var(--dark)}
.toast{
  position:fixed;bottom:24px;right:24px;z-index:2000;
  background:#111827;color:white;padding:12px 18px;border-radius:10px;
  font-size:13px;font-weight:500;display:flex;align-items:center;gap:8px;
  transform:translateY(80px);opacity:0;transition:.3s ease;pointer-events:none;
}
body.dark .toast{background:#f1f5f9;color:#111827}
.toast.show{transform:none;opacity:1}
</style>
</head>
<body>

<div class="app">
  <!-- ══════════ SIDEBAR ══════════ -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div class="logo-mark">BCC</div>
      <div>
        <div class="logo-name">CenterCredit</div>
        <div class="logo-sub">Панель управления</div>
      </div>
    </div>

    <div class="sidebar-scroll">
      <div class="nav-label">Главное</div>
      <div class="nav-item active" data-page="dashboard" onclick="nav(this)">
